<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <AssemblyName>FabInspector.Core</AssemblyName>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>FabInspector.Core</RootNamespace>
    <SignAssembly>False</SignAssembly>
    <Version>3.2.0</Version>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="CustomRules\**" />
    <EmbeddedResource Remove="CustomRules\**" />
    <None Remove="CustomRules\**" />
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="FabInspectorSerializerContext.cs" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="FabInspector.Tests" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Azure.Core" Version="1.53.0" />
    <PackageReference Include="JsonLogic" Version="6.0.2" />
    <PackageReference Include="JsonPatch.Net" Version="5.0.2" />
    <PackageReference Include="JsonPath.Net" Version="3.0.2" />
  </ItemGroup>

</Project>
