{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "Domain": "<your-tenant>.onmicrosoft.com",
    "TenantId": "<your-tenant-guid-or-common>",
    "ClientId": "<your-app-registration-client-id>",
    "CallbackPath": "/signin-oidc",
    "SignedOutCallbackPath": "/signout-callback-oidc"
  },
  "FabInspector": {
    "DownstreamScopes": {
      "PowerBi": [ "https://analysis.windows.net/powerbi/api/.default" ],
      "FabricItems": [ "https://api.fabric.microsoft.com/.default" ],
      "OneLake": [ "https://storage.azure.com/.default" ]
    }
  },
  "Workload": {
    "Auth": {
      "//": "WorkloadAppId is the AAD app id of THIS workload backend (audience).",
      "WorkloadAppId": "<your-workload-app-registration-client-id>",
      "//FabricAppId": "Fabric service appId. Override only for sovereign clouds.",
      "FabricAppId": "871c010f-5e61-4fb1-83ac-98610a7e9110",
      "//Authority": "OIDC authority for JWKS. Use a per-tenant URL for single-tenant deployments.",
      "Authority": "https://login.microsoftonline.com/common/v2.0",
      "//AllowedTenants": "If set, incoming token 'tid' must be in this list.",
      "AllowedTenants": [],
      "RequiredSubjectScope": "FabricWorkloadControl",
      "//AllowAnonymousInDevelopment": "Honoured only when ASPNETCORE_ENVIRONMENT=Development.",
      "AllowAnonymousInDevelopment": false
    }
  }
}
