@page "/fabric-launch/ruleset"
@rendermode InteractiveServer
@using System.Net.Http.Json
@using System.Text
@using System.Text.Json
@using FabInspector.Web.Workload
@using FabInspector.Web.Workload.Contracts
@using FabInspector.Web.Workload.Stores
@using Microsoft.AspNetCore.WebUtilities
@inject NavigationManager Nav
@inject IItemDefinitionStore Store
@inject IJSRuntime JS
@inject IHttpContextAccessor HttpContextAccessor

<PageTitle>FabInspector — Rule Set</PageTitle>

<h1>FabInspector rule set</h1>

@if (string.IsNullOrEmpty(_workspaceId) || string.IsNullOrEmpty(_itemId))
{
    <div class="alert alert-warning">Launch this editor from inside Fabric — workspace and item IDs must be supplied via query string.</div>
}
else
{
    <p class="text-muted small">Workspace: <code>@_workspaceId</code> / Item: <code>@_itemId</code></p>

    <div class="mb-3">
        <label class="form-label">rules.json</label>
        <textarea class="form-control font-monospace" rows="20" @bind="_rulesJson"></textarea>
    </div>

    @if (!string.IsNullOrEmpty(_validationMessage))
    {
        <div class="alert @(_validationOk ? "alert-success" : "alert-danger")">@_validationMessage</div>
    }

    <button type="button" class="btn btn-outline-secondary me-2" @onclick="ValidateJson">Validate JSON</button>
    <button type="button" class="btn btn-primary me-2" @onclick="SaveAsync" disabled="@_busy">Save</button>
    <button type="button" class="btn btn-success me-2" @onclick="RunNowAsync" disabled="@_busy">Run now</button>
    <button type="button" class="btn btn-outline-success" @onclick="RunAsJobAsync" disabled="@_busy">Run as Fabric job</button>

    @if (!string.IsNullOrEmpty(_status))
    {
        <p class="mt-3"><em>@_status</em></p>
    }
}

@code {
    private string? _workspaceId;
    private string? _itemId;
    private string _rulesJson = "{\n  \"rules\": []\n}";
    private string? _validationMessage;
    private bool _validationOk;
    private string? _status;
    private bool _busy;

    protected override async Task OnInitializedAsync()
    {
        var qs = QueryHelpers.ParseQuery(Nav.ToAbsoluteUri(Nav.Uri).Query);
        if (qs.TryGetValue("workspaceObjectId", out var ws)) _workspaceId = ws;
        if (qs.TryGetValue("itemObjectId", out var item)) _itemId = item;

        if (Guid.TryParse(_workspaceId, out var wsGuid) && Guid.TryParse(_itemId, out var itGuid))
        {
            var envelope = await Store.GetAsync(WorkloadItemTypes.RuleSet, wsGuid, itGuid);
            var part = envelope?.Definition?.Parts.FirstOrDefault(p => p.Path == WorkloadItemTypes.Parts.RulesJson);
            if (part != null)
            {
                _rulesJson = Encoding.UTF8.GetString(Convert.FromBase64String(part.Payload));
            }
        }
    }

    private void ValidateJson()
    {
        try
        {
            using var _ = JsonDocument.Parse(_rulesJson);
            _validationOk = true;
            _validationMessage = "JSON is valid.";
        }
        catch (JsonException ex)
        {
            _validationOk = false;
            _validationMessage = $"Invalid JSON: {ex.Message}";
        }
    }

    private async Task SaveAsync()
    {
        ValidateJson();
        if (!_validationOk) return;
        if (!Guid.TryParse(_workspaceId, out var wsGuid) || !Guid.TryParse(_itemId, out var itGuid)) return;

        _busy = true;
        try
        {
            var envelope = new ItemDefinitionEnvelope
            {
                Definition = new ItemDefinition
                {
                    Parts = new()
                    {
                        new ItemDefinitionPart
                        {
                            Path = WorkloadItemTypes.Parts.RulesJson,
                            PayloadType = "InlineBase64",
                            Payload = Convert.ToBase64String(Encoding.UTF8.GetBytes(_rulesJson))
                        }
                    }
                }
            };
            await Store.UpsertAsync(WorkloadItemTypes.RuleSet, wsGuid, itGuid, envelope);

            // Best-effort: ask the Fabric host to persist via itemCrud.updateItem.
            try
            {
                await JS.InvokeVoidAsync("fabricHost.updateItem", _rulesJson);
            }
            catch { /* standalone mode */ }

            _status = $"Saved at {DateTime.UtcNow:O}.";
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task RunNowAsync()
    {
        if (!Guid.TryParse(_workspaceId, out var wsGuid) || !Guid.TryParse(_itemId, out var itGuid)) return;
        _busy = true;
        _status = "Starting in-editor run…";
        try
        {
            var http = new HttpClient { BaseAddress = new Uri(Nav.BaseUri) };
            var jobInstanceId = Guid.NewGuid();
            var resp = await http.PostAsync(
                $"api/workload/jobs/{WorkloadItemTypes.RuleSet}/{wsGuid}/{itGuid}/{WorkloadItemTypes.Jobs.RunRules}/{jobInstanceId}",
                content: null);
            _status = resp.IsSuccessStatusCode
                ? $"Run started — jobInstanceId {jobInstanceId}. Use Recent Runs to track progress."
                : $"Failed to start: {resp.StatusCode}";
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task RunAsJobAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("fabricHost.runItemJob", WorkloadItemTypes.Jobs.RunRules);
            _status = "Requested Fabric host to start job.";
        }
        catch (Exception ex)
        {
            _status = $"Could not call Fabric host: {ex.Message}";
        }
    }
}
