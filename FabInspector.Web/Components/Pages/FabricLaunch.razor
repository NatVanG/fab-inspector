@page "/fabric-launch"
@rendermode InteractiveServer
@using FabInspector.Web.Components.Shared
@using Microsoft.AspNetCore.WebUtilities
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>FabInspector (Fabric)</PageTitle>

<h1>FabInspector — Fabric workload</h1>

<p class="text-muted small">
    Launched inside Microsoft Fabric. Workspace and item context were supplied by the host.
</p>

<InspectionForm
    InitialWorkspaceId="@_workspaceId"
    InitialItemId="@_itemId"
    InitialRulesFileUrl="@_rulesFileUrl"
    LockHostFields="true" />

@code {
    private string? _workspaceId;
    private string? _itemId;
    private string? _rulesFileUrl;

    protected override void OnInitialized()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var qs = QueryHelpers.ParseQuery(uri.Query);

        if (qs.TryGetValue("workspaceObjectId", out var ws)) _workspaceId = ws;
        if (qs.TryGetValue("itemObjectId", out var item)) _itemId = item;
        if (qs.TryGetValue("rulesFileUrl", out var rules)) _rulesFileUrl = rules;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Notify the Fabric host container that we are ready to receive
            // messages (theme, additional context, etc.). Safe no-op when the
            // app is not embedded.
            try
            {
                await JS.InvokeVoidAsync("fabricHost.notifyContainerReady");
            }
            catch
            {
                // Ignore — running standalone (not inside Fabric iframe).
            }
        }
    }
}
