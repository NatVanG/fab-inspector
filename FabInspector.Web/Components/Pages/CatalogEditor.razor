@page "/fabric-launch/catalog"
@rendermode InteractiveServer
@using System.Net.Http
@using System.Text
@using System.Text.Json
@using FabInspector.Web.Workload
@using FabInspector.Web.Workload.Contracts
@using FabInspector.Web.Workload.Stores
@using Microsoft.AspNetCore.WebUtilities
@inject NavigationManager Nav
@inject IItemDefinitionStore Store
@inject IJSRuntime JS

<PageTitle>FabInspector — Rules Catalog</PageTitle>

<h1>FabInspector rules catalog</h1>

@if (string.IsNullOrEmpty(_workspaceId) || string.IsNullOrEmpty(_itemId))
{
    <div class="alert alert-warning">Launch this editor from inside Fabric — workspace and item IDs must be supplied via query string.</div>
}
else
{
    <p class="text-muted small">Workspace: <code>@_workspaceId</code> / Item: <code>@_itemId</code></p>

    <div class="mb-3">
        <label class="form-label">Catalog name</label>
        <input class="form-control" @bind="_catalog.Name" />
    </div>

    <h5>Referenced rule sets</h5>
    <table class="table table-sm align-middle">
        <thead>
            <tr>
                <th>Display name</th>
                <th>Workspace ID</th>
                <th>Item ID</th>
                <th>Disabled</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var p in _catalog.RuleSets)
        {
            <tr>
                <td><input class="form-control form-control-sm" @bind="p.DisplayName" /></td>
                <td><input class="form-control form-control-sm" @bind="p.WorkspaceId" /></td>
                <td><input class="form-control form-control-sm" @bind="p.ItemId" /></td>
                <td><input type="checkbox" class="form-check-input" @bind="p.Disabled" /></td>
                <td><button class="btn btn-sm btn-outline-danger" @onclick="() => Remove(p)">Remove</button></td>
            </tr>
        }
        </tbody>
    </table>
    <button class="btn btn-sm btn-outline-secondary mb-3" @onclick="Add">Add reference</button>

    @if (!string.IsNullOrEmpty(_status))
    {
        <div class="alert alert-info">@_status</div>
    }

    <button type="button" class="btn btn-primary me-2" @onclick="SaveAsync" disabled="@_busy">Save</button>
    <button type="button" class="btn btn-success me-2" @onclick="RunNowAsync" disabled="@_busy">Run all (now)</button>
    <button type="button" class="btn btn-outline-success" @onclick="RunAsJobAsync" disabled="@_busy">Run all (as Fabric job)</button>
}

@code {
    private string? _workspaceId;
    private string? _itemId;
    private RulesCatalogPayload _catalog = new();
    private string? _status;
    private bool _busy;

    protected override async Task OnInitializedAsync()
    {
        var qs = QueryHelpers.ParseQuery(Nav.ToAbsoluteUri(Nav.Uri).Query);
        if (qs.TryGetValue("workspaceObjectId", out var ws)) _workspaceId = ws;
        if (qs.TryGetValue("itemObjectId", out var item)) _itemId = item;

        if (Guid.TryParse(_workspaceId, out var wsGuid) && Guid.TryParse(_itemId, out var itGuid))
        {
            var envelope = await Store.GetAsync(WorkloadItemTypes.RulesCatalog, wsGuid, itGuid);
            var part = envelope?.Definition?.Parts.FirstOrDefault(p => p.Path == WorkloadItemTypes.Parts.CatalogJson);
            if (part != null)
            {
                var json = Encoding.UTF8.GetString(Convert.FromBase64String(part.Payload));
                _catalog = JsonSerializer.Deserialize<RulesCatalogPayload>(json) ?? new();
            }
        }
    }

    private void Add() => _catalog.RuleSets.Add(new RulesCatalogPointer());
    private void Remove(RulesCatalogPointer p) => _catalog.RuleSets.Remove(p);

    private async Task SaveAsync()
    {
        if (!Guid.TryParse(_workspaceId, out var wsGuid) || !Guid.TryParse(_itemId, out var itGuid)) return;
        _busy = true;
        try
        {
            var json = JsonSerializer.Serialize(_catalog, new JsonSerializerOptions { WriteIndented = true });
            var envelope = new ItemDefinitionEnvelope
            {
                Definition = new ItemDefinition
                {
                    Parts = new()
                    {
                        new ItemDefinitionPart
                        {
                            Path = WorkloadItemTypes.Parts.CatalogJson,
                            PayloadType = "InlineBase64",
                            Payload = Convert.ToBase64String(Encoding.UTF8.GetBytes(json))
                        }
                    }
                }
            };
            await Store.UpsertAsync(WorkloadItemTypes.RulesCatalog, wsGuid, itGuid, envelope);

            try { await JS.InvokeVoidAsync("fabricHost.updateItem", json); } catch { }

            _status = $"Saved at {DateTime.UtcNow:O}.";
        }
        finally { _busy = false; }
    }

    private async Task RunNowAsync()
    {
        if (!Guid.TryParse(_workspaceId, out var wsGuid) || !Guid.TryParse(_itemId, out var itGuid)) return;
        _busy = true;
        try
        {
            var http = new HttpClient { BaseAddress = new Uri(Nav.BaseUri) };
            var jobInstanceId = Guid.NewGuid();
            var resp = await http.PostAsync(
                $"api/workload/jobs/{WorkloadItemTypes.RulesCatalog}/{wsGuid}/{itGuid}/{WorkloadItemTypes.Jobs.RunCatalog}/{jobInstanceId}",
                content: null);
            _status = resp.IsSuccessStatusCode
                ? $"Run started — jobInstanceId {jobInstanceId}."
                : $"Failed to start: {resp.StatusCode}";
        }
        finally { _busy = false; }
    }

    private async Task RunAsJobAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("fabricHost.runItemJob", WorkloadItemTypes.Jobs.RunCatalog);
            _status = "Requested Fabric host to start job.";
        }
        catch (Exception ex)
        {
            _status = $"Could not call Fabric host: {ex.Message}";
        }
    }
}
