<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">FabInspector.Web</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="inspect">
                <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Inspect
            </NavLink>
        </div>

        <AuthorizeView>
            <Authorized>
                <div class="nav-item px-3 text-light small">
                    Signed in as <strong>@context.User.Identity?.Name</strong>
                </div>
                <div class="nav-item px-3">
                    <a class="nav-link" href="MicrosoftIdentity/Account/SignOut">Sign out</a>
                </div>
            </Authorized>
            <NotAuthorized>
                <div class="nav-item px-3">
                    <a class="nav-link" href="MicrosoftIdentity/Account/SignIn">Sign in</a>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</div>

