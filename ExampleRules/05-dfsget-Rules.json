{
  "rules": [
    {
      "id": "EXECUTE_DFS_GET",
      "name": "Execute Dfs Get",
      "description": "",
      "itemType": "none",
      "disabled": true,
      "test": [
        {
          "dfsget": [
            "https://onelake.dfs.fabric.microsoft.com/{context-fabricworkspace}/{context-fabricitem}/Files/{folder}/{fileName}",
            "history/capacities/2026/06/01",
            "capacities.json"
          ]
        },
        []
      ]
    },
    {
      "id": "ONELAKE_DAXQUERY_COUNT",
      "name": "Count items in Results array from OneLake JSON",
      "description": "Fetches a OneLake JSON file using dfsget and verifies the Results array can be counted.",
      "itemType": "None",
      "disabled": true,
      "test": [
        {
          ">=": [
            {
              "count": [
                {
                  "query": [
                    {
                      "dfsget": [
                        "https://onelake.dfs.fabric.microsoft.com/FUAM/FUAM_Performance.Lakehouse/Files/PBI-Performance/PowerBIPerformanceData.json"
                      ]
                    },
                    {
                      "path": "$.events[?@.name == 'Execute DAX Query']"
                    }
                  ]
                }
              ]
            },
            0
          ]
        },
        true
      ]
    },
    {
      "id": "ONELAKE_DAXQUERY_EXECUTIONS",
      "name": "Return each DAX query execution",
      "description": "Fetches OneLake 'Execute DAX Query' events and returns the raw daxquery execution result for each event.",
      "itemType": "None",
      "disabled": false,
      "test": [
        {
          "map": [
            {
              "query": [
                {
                  "dfsget": [
                    "https://onelake.dfs.fabric.microsoft.com/FUAM/FUAM_Performance.Lakehouse/Files/PBI-Performance/PowerBIPerformanceData.json"
                  ]
                },
                {
                  "path": "$.events[?@.name == 'Execute DAX Query']"
                }
              ]
            },
            {
              "daxquery": [
                {
                  "path": "$.metrics.QueryText"
                }
              ]
            }
          ]
        },
        []
      ]
    },
    {
      "id": "ONELAKE_DAXQUERY_RESULTS",
      "name": "Return IDs of events whose DAX query fails",
      "description": "Executes each DAX query found in OneLake 'Execute DAX Query' events and returns the event IDs for queries that return no results.",
      "itemType": "None",
      "disabled": true,
      "test": [
        {
          "map": [
            {
              "filter": [
                {
                  "query": [
                    {
                      "dfsget": [
                        "https://onelake.dfs.fabric.microsoft.com/FUAM/FUAM_Performance.Lakehouse/Files/PBI-Performance/PowerBIPerformanceData.json"
                      ]
                    },
                    {
                      "path": "$.events[?@.name == 'Execute DAX Query']"
                    }
                  ]
                },
                {
                  "<=": [
                    {
                      "count": [
                        {
                          "query": [
                            {
                              "daxquery": [
                                {
                                  "path": "$.metrics.QueryText"
                                }
                              ]
                            },
                            {
                              "var": "results.0.tables.0.rows"
                            }
                          ]
                        }
                      ]
                    },
                    0
                  ]
                }
              ]
            },
            {
              "var": "id"
            }
          ]
        },
        []
      ]
    }
  ]
}
