<?xml version="1.0" encoding="utf-8" ?>
<!--
    Workload-level manifest consumed by the Fabric Extensibility Toolkit
    DevGateway and the Workload Hub publishing pipeline. Placeholders
    ({{...}}) are substituted by scripts/Build/BuildManifestPackage.ps1
    from the appropriate .env.{environment} file.
-->
<WorkloadManifestConfiguration
    xmlns="http://schemas.microsoft.com/fabric/workload-manifest"
    Name="{{WORKLOAD_NAME}}"
    Version="{{WORKLOAD_VERSION}}">

    <Workload>
        <DisplayName>FabInspector</DisplayName>
        <Description>Run Fab Inspector rule sets against Fabric workspaces and items.</Description>
        <Publisher>FabInspector</Publisher>
    </Workload>

    <CloudServiceConfiguration>
        <AADApps>
            <AADApp
                Name="FrontendApp"
                AppId="{{FRONTEND_APP_ID}}"
                RedirectUri="{{FRONTEND_URL}}/close.html" />
        </AADApps>

        <ServiceEndpoints>
            <ServiceEndpoint
                Name="WorkloadBackend"
                Url="{{BACKEND_URL}}" />
        </ServiceEndpoints>
    </CloudServiceConfiguration>

</WorkloadManifestConfiguration>
